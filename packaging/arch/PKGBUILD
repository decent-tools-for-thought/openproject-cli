pkgname=openproject-cli
pkgver=0.1.0
pkgrel=1
pkgdesc='Command-line client for OpenProject API v3'
arch=('any')
url='https://github.com/decent-tools-for-thought/openproject-cli'
license=('unknown')
depends=('python')
source=("$pkgname-$pkgver.tar.gz::https://github.com/decent-tools-for-thought/openproject-cli/releases/download/v$pkgver/$pkgname-$pkgver.tar.gz")
sha256sums=('80ba7b7d9280dbcf837175bfcf8fb750e3a4f140d85a70d51c8a45e5dbeff80a')

package() {
  local extracted_dir
  extracted_dir="$(find "$srcdir" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  if [[ -z "$extracted_dir" ]]; then
    echo "Could not determine extracted source directory in $srcdir" >&2
    return 1
  fi

  install -Dm755 "$extracted_dir/openproject_cli.py" "$pkgdir/usr/bin/openproject-cli"
  install -Dm644 "$extracted_dir/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
